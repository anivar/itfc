{
  "$schema": "https://biomejs.dev/schemas/2.4.15/schema.json",
  "vcs": { "enabled": false },
  "files": {
    "ignoreUnknown": true,
    "maxSize": 33554432,
    "includes": [
      "src/**",
      "scripts/**",
      "*.mjs",
      "*.json",
      "!src/data/pages.json",
      "!src/data/redirects.json",
      "!dist",
      "!node_modules"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "javascript": {
    "formatter": { "quoteStyle": "single", "semicolons": "always" }
  },
  "linter": {
    "enabled": true,
    "rules": { "recommended": true }
  }
}
