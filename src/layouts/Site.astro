---
import { SEO } from 'astro-seo';
import '~/styles/global.css';
import Footer from '~/components/Footer.astro';
import Header from '~/components/Header.astro';
import { SITE } from '~/data/site';
import { bp } from '~/lib/with-base';

interface Props {
  title?: string;
  description?: string;
  canonicalPath?: string;
  ogImage?: string;
  article?: boolean;
}
const { title, description, canonicalPath, ogImage = '/brand/itfc-logo.png', article = false } = Astro.props;
const fullTitle = title ? `${title} | ${SITE.name}` : SITE.name;
const siteOrigin = Astro.site ?? new URL(`https://${SITE.domain}/`);
const canonical = canonicalPath
  ? new URL(bp(canonicalPath), siteOrigin).toString()
  : Astro.url.toString();
const ogImageAbs = ogImage.startsWith('http')
  ? ogImage
  : new URL(bp(ogImage), siteOrigin).toString();
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#6b1f1f" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" href={bp('/favicon.ico')} type="image/vnd.microsoft.icon" />
    {/* Brand stylesheet loaded after global.css so brand specifics
        (article fonts, view layouts, slideshow sizing) win where they exist. */}
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap@3.3.7/dist/css/bootstrap.min.css"
      media="all"
    />
    <link rel="stylesheet" href={bp('/themes/bootstrap/css/3.3.7/overrides.min.css')} media="all" />
    <link rel="stylesheet" href={bp('/themes/itfc_agov_subtheme/css/itfc_style_v2.css')} media="all" />
    <SEO
      title={fullTitle}
      description={description}
      canonical={canonical}
      openGraph={{
        basic: {
          title: fullTitle,
          type: article ? 'article' : 'website',
          image: ogImageAbs,
        },
        optional: { siteName: SITE.name, description },
      }}
    />
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to content</a>
    <Header />
    <main id="main">
      <slot />
    </main>
    <Footer />
    <script is:inline>
      // Drupal Views slideshow re-implementation: rotate every 5s with a
      // crossfade. Supports any number of slideshow blocks on the page.
      (function () {
        var blocks = document.querySelectorAll(
          '.views_slideshow_cycle_main, .views_slideshow_main'
        );
        if (!blocks.length) return;
        blocks.forEach(function (block) {
          var slides = block.querySelectorAll(
            '.views_slideshow_cycle_slide, .views_slideshow_slide'
          );
          if (slides.length < 2) return;
          // Strip Drupal's "hidden" class — JS now controls visibility.
          slides.forEach(function (s) {
            s.classList.remove('views_slideshow_cycle_hidden');
          });
          var idx = 0;
          slides[0].classList.add('is-active');
          // Build a small dot pager.
          var pager = document.createElement('div');
          pager.className = 'views_slideshow_pager_fields';
          var dots = [];
          slides.forEach(function (_s, i) {
            var b = document.createElement('button');
            b.type = 'button';
            b.className = 'views_slideshow_pager_field_item' + (i === 0 ? ' is-active' : '');
            b.setAttribute('aria-label', 'Go to slide ' + (i + 1));
            b.addEventListener('click', function () { go(i); });
            pager.appendChild(b);
            dots.push(b);
          });
          block.appendChild(pager);
          function go(next) {
            if (next === idx) return;
            slides[idx].classList.remove('is-active');
            dots[idx].classList.remove('is-active');
            idx = next;
            slides[idx].classList.add('is-active');
            dots[idx].classList.add('is-active');
          }
          var timer = setInterval(function () {
            go((idx + 1) % slides.length);
          }, 5000);
          block.addEventListener('mouseenter', function () { clearInterval(timer); });
          block.addEventListener('mouseleave', function () {
            timer = setInterval(function () { go((idx + 1) % slides.length); }, 5000);
          });
        });
      })();
    </script>
  </body>
</html>
