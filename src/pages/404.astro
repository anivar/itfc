---
import Site from '~/layouts/Site.astro';
import { bp } from '~/lib/with-base';
---
<Site title="Page not found" description="The page you requested could not be found.">
  <div class="page page--404">
    <article class="content">
      <h1>404</h1>
      <p>We couldn't find that page.</p>
      <p>
        <a href={bp('/')}>Home</a>
        &nbsp;·&nbsp;
        <a href={bp('/sitemap')}>Browse all pages</a>
      </p>
    </article>
  </div>

  <style>
    .page--404 { text-align: center; }
    .page--404 h1 { font-size: 2.5rem; margin-bottom: 0.5rem; }
    .page--404 p { color: var(--color-muted); margin-top: 1.5rem; }
  </style>
</Site>
