---
import pages from '~/lib/pages';
import { SITE } from '~/data/site';
import Site from '~/layouts/Site.astro';
import { withBase } from '~/lib/with-base';

type Page = {
  slug: string;
  title: string;
  body_html: string;
};

const all = pages as Page[];
const home = all.find((p) => p.slug === 'index');
const homeHtml = home ? withBase(home.body_html) : '';
---
<Site title={SITE.name} description={SITE.tagline}>
  <div role="main" class="main-container container js-quickedit-main-content">
    {home ? (
      <div class="row">
        <section class="col-sm-12">
          <div class="region region-content" set:html={homeHtml}></div>
        </section>
      </div>
    ) : (
      <div class="page">
        <article class="content">
          <h1>{SITE.name}</h1>
          <p class="home__tagline">{SITE.tagline}</p>
          <p><a href={`${import.meta.env.BASE_URL}sitemap`.replace(/\/+/g, '/')}>Browse the sitemap →</a></p>
        </article>
      </div>
    )}
  </div>
</Site>

<style>
  .home__tagline { font-size: 1.05rem; color: var(--color-muted); }
</style>
