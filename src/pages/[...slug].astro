---
import pages from '~/lib/pages';
import Site from '~/layouts/Site.astro';
import { withBase } from '~/lib/with-base';
import { tabifyTwoViewBlocks } from '~/lib/views-to-tabs';
import { lazifyImages } from '~/lib/lazify-images';

type Page = {
  slug: string;
  title: string;
  body_html: string;
};

export async function getStaticPaths() {
  const all = pages as Page[];
  // Drop junk slugs that came from URL-encoded query strings in the
  // original Drupal capture (e.g. "RightToKnow?q=OurTeam") and old
  // CMS entry points (index.php/*).
  const isJunk = (s: string) =>
    !s ||
    s === 'index' ||
    s === 'user/login' ||
    s.startsWith('user/') ||
    s.includes('?') ||
    s.includes('=') ||
    s.startsWith('index.php/') ||
    s.includes('/Special:');
  // Empty taxonomy/term/N stubs: Drupal generated thousands of these
  // category index pages; many were captured by Wayback as title-only HTML
  // (no body). They render as blank pages and bloat the sitemap. Drop the
  // empty ones; substantive taxonomy pages with real body content stay.
  // node/N pages are NOT filtered even if short — several are legit
  // carousel-slide / feature-card landings (e.g. node/1722 COVID-19 RELIEF).
  const wordCount = (html: string) =>
    (html.replace(/<[^>]+>/g, ' ').match(/\w+/g) || []).length;
  const isEmptyShell = (p: Page) =>
    p.slug.startsWith('taxonomy/term/') && wordCount(p.body_html || '') < 30;
  // Wayback captured ~30 inclusionroundtable2014/* URLs as the legacy CMS's
  // "Fatal Error." page (engine 500'd at capture time). They have no real
  // content, just an error template. Drop them.
  const isErrorCapture = (p: Page) =>
    (p.title || '').trim().toLowerCase().startsWith('fatal error');
  return all
    .filter((p) => !isJunk(p.slug) && !isEmptyShell(p) && !isErrorCapture(p))
    .map((p) => ({
      params: { slug: p.slug },
      props: { page: p },
    }));
}

const { page } = Astro.props as { page: Page };
// Landings whose body holds two Drupal view-display blocks (block_1 / block_2)
// originally rendered as switchable tabs. Reconstruct that here.
const tabbed = page.slug === 'networks' || page.slug === 'events'
  ? tabifyTwoViewBlocks(page.body_html, { idPrefix: `tabs-${page.slug}` })
  : page.body_html;
const html = lazifyImages(withBase(tabbed));
const description = (html || '')
  .replace(/<[^>]+>/g, ' ')
  .replace(/\s+/g, ' ')
  .trim()
  .slice(0, 200);

// Mirror Drupal body classes so brand CSS rules like
// `.page-title--Research`, `.path-aboutus` apply on legacy pages.
const titleSlug = (page.title || page.slug).replace(/\s+/g, '_');
const pathSlug = page.slug.replace(/\//g, '-');
const bodyClass = `page-title--${titleSlug} path-${pathSlug}`;
---
<Site title={page.title} description={description} canonicalPath={`/${page.slug}`} bodyClass={bodyClass}>
  <div class="page">
    <article class="content">
      {/* Brand v5 stylesheet styles `h1.page-header` as a blue-gray gradient
          banner, but only for an explicit allow-list of body classes (about us,
          team, governing body, policies, donate, ITfC Team, sitemap, etc.).
          Other pages keep the plain h1 — which matches the live Drupal site. */}
      <h1 class="page-header">{page.title}</h1>
      <div set:html={html}></div>
    </article>
  </div>
</Site>
{page.slug === 'events' && (
  <script is:inline>
    /* Client-side pagination for the /events landing.
     *
     * The captured body_html dumps all 500+ event rows inline. Lazy
     * image loading helps initial paint but the DOM is still heavy
     * and scrolling 500 cards is unkind. Slice .views-row into pages
     * of N inside each tab panel and render a pager bar.
     *
     * Graceful degradation: if this script doesn't run (JS off,
     * older browser, etc.), all rows stay visible. */
    (function () {
      var PER_PAGE = 12;

      function paginate(panel) {
        var content = panel.querySelector('.view-content');
        if (!content) return;
        var rows = Array.prototype.slice.call(
          content.querySelectorAll(':scope > .views-row')
        );
        if (rows.length <= PER_PAGE) return;

        var totalPages = Math.ceil(rows.length / PER_PAGE);
        var current = 1;

        var pager = document.createElement('nav');
        pager.className = 'itfc-pager';
        pager.setAttribute('aria-label', 'Events pagination');
        panel.appendChild(pager);

        function render() {
          for (var i = 0; i < rows.length; i++) {
            var page = Math.floor(i / PER_PAGE) + 1;
            rows[i].style.display = page === current ? '' : 'none';
          }
          pager.innerHTML = '';
          var mk = function (label, target, opts) {
            opts = opts || {};
            var b = document.createElement('button');
            b.type = 'button';
            b.className = 'itfc-pager-btn' + (opts.active ? ' is-active' : '');
            b.textContent = label;
            if (opts.disabled) b.disabled = true;
            if (opts.aria) b.setAttribute('aria-label', opts.aria);
            b.addEventListener('click', function () {
              current = target;
              render();
              panel.scrollIntoView({ behavior: 'smooth', block: 'start' });
            });
            pager.appendChild(b);
          };

          mk('‹ Prev', Math.max(1, current - 1), {
            disabled: current === 1, aria: 'Previous page',
          });

          // Show a compact window of page numbers around the current page
          // (first, last, current ± 2, with ellipses).
          var shown = {};
          var add = function (n) { shown[n] = true; };
          add(1); add(totalPages);
          for (var d = -2; d <= 2; d++) {
            var n = current + d;
            if (n >= 1 && n <= totalPages) add(n);
          }
          var nums = Object.keys(shown).map(Number).sort(function (a, b) { return a - b; });
          for (var i = 0; i < nums.length; i++) {
            if (i > 0 && nums[i] !== nums[i - 1] + 1) {
              var sep = document.createElement('span');
              sep.className = 'itfc-pager-sep';
              sep.textContent = '…';
              pager.appendChild(sep);
            }
            (function (n) {
              mk(String(n), n, { active: n === current, aria: 'Page ' + n });
            })(nums[i]);
          }

          mk('Next ›', Math.min(totalPages, current + 1), {
            disabled: current === totalPages, aria: 'Next page',
          });

          var info = document.createElement('span');
          info.className = 'itfc-pager-info';
          var start = (current - 1) * PER_PAGE + 1;
          var end = Math.min(rows.length, current * PER_PAGE);
          info.textContent = start + '–' + end + ' of ' + rows.length;
          pager.appendChild(info);
        }

        render();
      }

      function init() {
        var panels = document.querySelectorAll('.itfc-tab-panel');
        for (var i = 0; i < panels.length; i++) paginate(panels[i]);
      }
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', init);
      } else {
        init();
      }
    })();
  </script>
)}
