---
import pages from '~/lib/pages';
import Site from '~/layouts/Site.astro';
import { withBase } from '~/lib/with-base';

type Page = {
  slug: string;
  title: string;
  body_html: string;
};

export async function getStaticPaths() {
  const all = pages as Page[];
  // Drop junk slugs that came from URL-encoded query strings in the
  // original Drupal capture (e.g. "RightToKnow?q=OurTeam") and old
  // CMS entry points (index.php/*).
  const isJunk = (s: string) =>
    !s ||
    s === 'index' ||
    s.includes('?') ||
    s.includes('=') ||
    s.startsWith('index.php/');
  // Empty taxonomy/term/N stubs: Drupal generated thousands of these
  // category index pages; many were captured by Wayback as title-only HTML
  // (no body). They render as blank pages and bloat the sitemap. Drop the
  // empty ones; substantive taxonomy pages with real body content stay.
  const wordCount = (html: string) =>
    (html.replace(/<[^>]+>/g, ' ').match(/\w+/g) || []).length;
  const isEmptyShell = (p: Page) =>
    (p.slug.startsWith('taxonomy/term/') || p.slug.startsWith('node/')) &&
    wordCount(p.body_html || '') < 30;
  return all
    .filter((p) => !isJunk(p.slug) && !isEmptyShell(p))
    .map((p) => ({
      params: { slug: p.slug },
      props: { page: p },
    }));
}

const { page } = Astro.props as { page: Page };
const html = withBase(page.body_html);
const description = (html || '')
  .replace(/<[^>]+>/g, ' ')
  .replace(/\s+/g, ' ')
  .trim()
  .slice(0, 200);

// Mirror Drupal body classes so brand CSS rules like
// `.page-title--Research`, `.path-aboutus` apply on legacy pages.
const titleSlug = (page.title || page.slug).replace(/\s+/g, '_');
const pathSlug = page.slug.replace(/\//g, '-');
const bodyClass = `page-title--${titleSlug} path-${pathSlug}`;
---
<Site title={page.title} description={description} canonicalPath={`/${page.slug}`} bodyClass={bodyClass}>
  <div class="page">
    <article class="content">
      {/* Brand v5 stylesheet styles `h1.page-header` as a blue-gray gradient
          banner, but only for an explicit allow-list of body classes (about us,
          team, governing body, policies, donate, ITfC Team, sitemap, etc.).
          Other pages keep the plain h1 — which matches the live Drupal site. */}
      <h1 class="page-header">{page.title}</h1>
      <div set:html={html}></div>
    </article>
  </div>
</Site>
