---
// /resources_all/page/N — pages 1..N. We pre-generate one static HTML
// per page from publications.json (CDX-derived ordering, newest first).
import Site from '~/layouts/Site.astro';
import PublicationsList from '~/components/PublicationsList.astro';
import publications from '~/data/publications.json';

const pageSize = 10;

export async function getStaticPaths() {
  const list = publications as unknown[];
  const totalPages = Math.ceil(list.length / 10);
  // Skip page 0 — that's served by /resources_all/index.astro.
  return Array.from({ length: totalPages - 1 }, (_, i) => ({
    params: { n: String(i + 1) },
  }));
}

const n = parseInt(Astro.params.n!, 10);
const totalCount = (publications as unknown[]).length;
---
<Site
  title={`Publications — page ${n + 1}`}
  description={`Page ${n + 1} of publications, papers, and reports from IT for Change (${totalCount} total).`}
  canonicalPath={`/resources_all/page/${n}`}
  bodyClass="page-title--Publications path-resources-all"
>
  <div class="page">
    <article class="content">
      <h1 class="page-header">Publications</h1>
      <PublicationsList page={n} pageSize={pageSize} />
    </article>
  </div>
</Site>
