---
// Header that mirrors the original Drupal Bootstrap navbar from
// https://web.archive.org/web/20260424201529/itforchange.net
import { NAV, SITE } from '~/data/site';
import { bp } from '~/lib/with-base';
---
<header class="navbar navbar-default container" id="navbar" role="banner">
  <div class="navbar-header">
    <div class="region region-navigation">
      <a class="logo navbar-btn pull-left" href={bp('/')} title="Home" rel="home">
        <img src={bp('/sites/default/files/high-res-itfc-logo1_4.png')} alt={SITE.name} />
      </a>
      <p class="navbar-text">{SITE.tagline}</p>
      <div class="search-block-form block block-search" role="search">
        <form action={bp('/sitemap')} method="get">
          <div class="form-item form-type-search form-no-label form-group">
            <label for="edit-keys" class="control-label sr-only">Search</label>
            <div class="input-group">
              <input
                id="edit-keys"
                class="form-search form-control"
                type="search"
                name="q"
                placeholder="Search"
                size="15"
              />
              <span class="input-group-btn">
                <button type="submit" class="btn btn-primary icon-only" aria-label="Search">
                  <span class="icon glyphicon glyphicon-search" aria-hidden="true"></span>
                </button>
              </span>
            </div>
          </div>
        </form>
      </div>
    </div>
    <button type="button" class="navbar-toggle collapsed" aria-controls="navbar-collapse"
            aria-expanded="false" data-target="#navbar-collapse">
      <span class="sr-only">Toggle navigation</span>
      <span class="icon-bar"></span>
      <span class="icon-bar"></span>
      <span class="icon-bar"></span>
    </button>
  </div>
  <div id="navbar-collapse" class="navbar-collapse collapse">
    <div class="region region-navigation-collapsible">
    <nav role="navigation" aria-labelledby="block-mainnavigation-menu" aria-label="Main navigation">
      <h2 class="sr-only" id="block-mainnavigation-menu">Main navigation</h2>
      <ul class="menu nav navbar-nav">
        {NAV.map((item) =>
          item.children ? (
            <li class="expanded dropdown">
              <a
                href={bp(item.href)}
                class="dropdown-toggle"
                data-toggle="dropdown"
                aria-haspopup="true"
                aria-expanded="false"
              >{item.label} <span class="caret"></span></a>
              <ul class="menu dropdown-menu">
                {item.children.map((child) => (
                  <li><a href={bp(child.href)}>{child.label}</a></li>
                ))}
              </ul>
            </li>
          ) : (
            <li>
              {item.external ? (
                <a href={item.href} target="_self" rel="noopener">{item.label}</a>
              ) : (
                <a href={bp(item.href)}>{item.label}</a>
              )}
            </li>
          )
        )}
      </ul>
    </nav>
    </div>
  </div>
</header>
<script is:inline>
  // Vanilla JS replacements for Bootstrap 3 navbar collapse + dropdowns
  // (we don't ship jQuery + bootstrap.js, so we wire the two interactions
  // we actually use: mobile collapse toggle and dropdown click-toggle).
  (function () {
    var toggle = document.querySelector('.navbar-toggle');
    var collapse = document.getElementById('navbar-collapse');
    if (toggle && collapse) {
      toggle.addEventListener('click', function () {
        var open = collapse.classList.toggle('in');
        toggle.classList.toggle('collapsed', !open);
        toggle.setAttribute('aria-expanded', open ? 'true' : 'false');
      });
    }
    function closeAll(except) {
      document.querySelectorAll('li.dropdown.open').forEach(function (li) {
        if (li !== except) {
          li.classList.remove('open');
          var t = li.querySelector('.dropdown-toggle');
          if (t) t.setAttribute('aria-expanded', 'false');
        }
      });
    }
    document.addEventListener('click', function (e) {
      var t = e.target.closest('.dropdown-toggle');
      if (t) {
        e.preventDefault();
        var li = t.parentElement;
        var willOpen = !li.classList.contains('open');
        closeAll(willOpen ? li : null);
        li.classList.toggle('open', willOpen);
        t.setAttribute('aria-expanded', willOpen ? 'true' : 'false');
        return;
      }
      if (!e.target.closest('li.dropdown')) closeAll(null);
    });
  })();
</script>
