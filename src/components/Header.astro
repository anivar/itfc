---
import { NAV, SITE } from '~/data/site';
import { bp } from '~/lib/with-base';
---
<header class="site-header">
  <div class="site-header__inner">
    <a href={bp('/')} class="brand" rel="home" title="Home">
      <img src={bp('/brand/itfc-logo.png')} alt={SITE.name} class="brand__logo" />
      <span class="brand__tag">{SITE.tagline}</span>
    </a>
    <form action={bp('/sitemap')} method="get" class="site-search" role="search">
      <label for="q" class="skip-link">Search</label>
      <input id="q" type="search" name="q" placeholder="Search pages…" />
      <button type="submit">Search</button>
    </form>
  </div>
</header>
<nav class="site-nav" role="navigation" aria-label="Main">
  <div class="site-nav__inner">
    {NAV.map((item) => (
      item.children ? (
        <div class="site-nav__group" data-open="false">
          <button type="button" class="site-nav__top" aria-haspopup="true" aria-expanded="false">{item.label} ▾</button>
          <div class="site-nav__menu" role="menu">
            {item.children.map((child) => (
              <a href={bp(child.href)}>{child.label}</a>
            ))}
          </div>
        </div>
      ) : (
        <a href={bp(item.href)}>{item.label}</a>
      )
    ))}
  </div>
</nav>
<script is:inline>
  // Click-to-toggle dropdowns so touch users (no :hover) can navigate.
  document.addEventListener('click', (e) => {
    const top = e.target.closest('.site-nav__top');
    if (top) {
      const group = top.parentElement;
      const open = group.dataset.open === 'true';
      document.querySelectorAll('.site-nav__group[data-open="true"]')
        .forEach((g) => {
          g.dataset.open = 'false';
          g.querySelector('.site-nav__top')?.setAttribute('aria-expanded', 'false');
        });
      if (!open) {
        group.dataset.open = 'true';
        top.setAttribute('aria-expanded', 'true');
      }
      e.preventDefault();
      return;
    }
    if (!e.target.closest('.site-nav__group')) {
      document.querySelectorAll('.site-nav__group[data-open="true"]')
        .forEach((g) => {
          g.dataset.open = 'false';
          g.querySelector('.site-nav__top')?.setAttribute('aria-expanded', 'false');
        });
    }
  });
</script>
