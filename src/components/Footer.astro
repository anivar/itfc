---
// Footer mirrors the 2026 Drupal footer markup so the brand stylesheet
// (`/themes/itfc_agov_subtheme/css/itfc_style_v2.css`) styles it the
// same as the original — `social__wrapper` + `social--<network>` pills.
import { FOOTER_LINKS, SITE } from '~/data/site';
import { bp } from '~/lib/with-base';
---
<footer class="footer container" role="contentinfo">
  <div class="region region-footer">
    <section class="block block-block-content clearfix">
      <div class="field field--name-body field--type-text-with-summary field--label-hidden field--item">
        <p>{SITE.address}.</p>
        <p>
          <a href={SITE.mapsUrl} rel="noopener">Directions on map.</a>
          {' '}Tel: {SITE.phone}. Email:
          {' '}<a href={SITE.emailHref}>{SITE.email}</a>
        </p>
      </div>
    </section>

    <section class="block block-block-content clearfix">
      <div class="social__wrapper field field--name-field-social-icon field--type-link field--label-visually_hidden">
        <div class="field--label sr-only">Social Icon</div>
        <div class="field__items">
          <div class="social__item field--item">
            <a href={SITE.social.twitter} target="_blank" rel="noopener" class="social--twitter">Follow us on Twitter</a>
          </div>
          <div class="social__item field--item">
            <a href={SITE.social.facebook} target="_blank" rel="noopener" class="social--facebook">Facebook</a>
          </div>
          <div class="social__item field--item">
            <a href={SITE.social.youtube} target="_blank" rel="noopener" class="social--youtube">Watch</a>
          </div>
          <div class="social__item field--item">
            <a href={SITE.emailHref} class="social--contact">Contact us</a>
          </div>
          <div class="social__item field--item">
            <a href={SITE.social.instagram} target="_blank" rel="noopener" class="social--instagram">Instagram</a>
          </div>
          <div class="social__item field--item">
            <a href={SITE.social.newsletter} target="_blank" rel="noopener" class="social--newsletter">Newsletter</a>
          </div>
        </div>
      </div>
    </section>

    <section class="block block-block-content clearfix">
      <div class="field field--name-body field--type-text-with-summary field--label-hidden field--item">
        <p>
          All content (except where explicitly stated) is licensed under a
          {' '}<a href={SITE.license.url} rel="license noopener">{SITE.license.name}</a>
        </p>
        <p>
          International License for widescale, free reproduction and translation.
        </p>
      </div>
    </section>

    <nav role="navigation" aria-label="Footer Quick Links">
      <h2 class="visually-hidden">Footer Quick Links</h2>
      <ul class="menu nav">
        {FOOTER_LINKS.map((link) => (
          <li><a href={bp(link.href)}>{link.label}</a></li>
        ))}
      </ul>
    </nav>

    <p class="footer__credit">
      Astro by <a href="https://anivar.net" rel="noopener" target="_blank">anivar.net</a>
    </p>
  </div>
</footer>
